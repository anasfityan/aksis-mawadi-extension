{
  "manifest_version": 3,
  "name": "AKSIS → موادي",
  "version": "1.0",
  "description": "استيراد الجدول والدرجات والرسائل من AKSIS إلى تطبيق موادي",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://aksis.istanbul.edu.tr/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "icons": {
    "48": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://aksis.istanbul.edu.tr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
